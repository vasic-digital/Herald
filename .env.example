# Herald — operator credentials + runtime configuration template.
#
# Copy this file to .env (git-ignored) and fill in real values. Resolution
# order per spec V3 §9.4: exported shell vars (from .bashrc / .zshrc) win;
# .env is the fallback layer only (never overrides shell exports).
#
# See docs/guides/OPERATOR_CREDENTIALS.md for step-by-step setup of every
# supported messenger + LLM dispatcher.

# ──────────────────────────────────────────────────────────────────────
# Wave 6 — pherald inbound runtime
# ──────────────────────────────────────────────────────────────────────

# HERALD_PROJECT_NAME pins the Claude Code session name. Unset = use the
# current working directory's basename. Final fallback = "Herald".
# Operator-locked Wave 6 decision (2026-05-22).
HERALD_PROJECT_NAME=
