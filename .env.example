# Herald — operator credentials + runtime configuration template.
#
# Copy this file to .env (git-ignored) and fill in real values. Resolution
# order per spec V3 §9.4: exported shell vars (from .bashrc / .zshrc) win;
# .env is the fallback layer only (never overrides shell exports).
#
# See docs/guides/OPERATOR_CREDENTIALS.md for step-by-step setup of every
# supported messenger + LLM dispatcher (including the new §11.4.98 MTProto
# automation harness).

# ──────────────────────────────────────────────────────────────────────
# Wave 6 — pherald inbound runtime
# ──────────────────────────────────────────────────────────────────────

# HERALD_PROJECT_NAME pins the Claude Code session name. Unset = use the
# current working directory's basename. Final fallback = "Herald".
# Operator-locked Wave 6 decision (2026-05-22).
HERALD_PROJECT_NAME=

# ──────────────────────────────────────────────────────────────────────
# HRD-011 Telegram Bot API (outbound + inbound long-poll)
# ──────────────────────────────────────────────────────────────────────

# Bot token from @BotFather. Shape: NNNNNNNNNN:35-char-base64ish.
HERALD_TGRAM_BOT_TOKEN=
# Target chat ID. Private DM = positive; group = negative; supergroup = -100<id>.
HERALD_TGRAM_CHAT_ID=
# Set to "1" ONLY when running TestSubscribe_LiveBotAPI with a hand-sent message
# (DEPRECATED per §11.4.98 — manual-dependency test, scheduled for MTProto rewrite).
HERALD_TGRAM_LIVE_INBOUND=

# ──────────────────────────────────────────────────────────────────────
# HRD-012 Claude Code dispatcher (Wave 6 inbound action engine)
# ──────────────────────────────────────────────────────────────────────

# Absolute path to the `claude` CLI. Default = PATH lookup of "claude".
HERALD_CLAUDE_BIN=
# Project identifier for the Claude session anchor. Operator-chosen
# (alphanumeric + dash + underscore). Default fallback = "Herald".
HERALD_CLAUDE_PROJECT_NAME=Herald
# Working directory for `claude --resume`. Default = ".".
HERALD_CLAUDE_WORKDIR=
# Pre-existing session UUID. Normally auto-bootstrapped; set only for
# diagnostics or for tests against a DEDICATED test-only session
# (§11.4.98 rule (2) — never reuse the dev conductor's UUID).
HERALD_CLAUDE_SESSION_UUID=

# ──────────────────────────────────────────────────────────────────────
# Wave 6.5 ticket-lifecycle authorisation
# ──────────────────────────────────────────────────────────────────────

# Comma-separated Telegram user IDs allowed to send "Done:" / "Reopen:"
# operator commands to pherald. NUMERIC IDs only (not @usernames).
HERALD_OPERATOR_IDS=

# ──────────────────────────────────────────────────────────────────────
# qaherald — pherald ↔ Telegram QA round-trip automation
# ──────────────────────────────────────────────────────────────────────

# QA bot token (NOTE: bot-to-bot driving doesn't work in groups — Telegram's
# privacy boundary blocks bots from seeing other bots' messages. This token
# is retained for legacy in-DM scenarios and qaherald audit-only flows;
# full closed-loop automation requires MTProto vars below per §11.4.98.)
HERALD_QA_BOT_TOKEN=

# ──────────────────────────────────────────────────────────────────────
# §11.4.98 — MTProto user-account harness (full-automation closed-loop)
# Required by Wave 8 Track B for COMPLIANT live e2e tests.
# See docs/guides/OPERATOR_CREDENTIALS.md §"MTProto setup" for step-by-step.
# ──────────────────────────────────────────────────────────────────────

# App api_id from https://my.telegram.org/apps (integer, ~5-8 digits).
HERALD_MTPROTO_APP_ID=
# App api_hash from https://my.telegram.org/apps (32-char hex).
HERALD_MTPROTO_APP_HASH=
# Phone number of the Telegram USER account that drives QA tests (E.164,
# e.g. +12025551234). NOT the bot — a real user account that is a member
# of the HERALD_TGRAM_CHAT_ID group. First run triggers an SMS / app-code
# login flow (§11.4.98 single-permitted-exception: one-time bootstrap).
HERALD_MTPROTO_PHONE=
# Cloud 2FA password if the user account has 2FA enabled. Optional;
# the login flow prompts only if Telegram returns SESSION_PASSWORD_NEEDED.
HERALD_MTPROTO_PASSWORD=
# Session file path. Default = ~/.config/herald/mtproto.session.
# Persisted after first login; subsequent runs reuse it (no human action).
HERALD_MTPROTO_SESSION_FILE=

# ──────────────────────────────────────────────────────────────────────
# Wave 4a HTTP/3 + TLS (optional override; auto-generated otherwise)
# ──────────────────────────────────────────────────────────────────────

# HERALD_TLS_CERT_FILE=
# HERALD_TLS_KEY_FILE=
