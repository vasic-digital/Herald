# .env.example — Herald V3 §26.5 quickstart credentials template.
#
# Copy this to the REPO ROOT as ".env" (which IS git-ignored per
# Universal Constitution §11.4.10) before running the quickstart
# compose. Resolution order is 12-factor aligned (spec §3.3):
#
#   1. explicit CLI flag (highest precedence)
#   2. shell-exported env var (.bashrc / .zshrc / k8s)
#   3. value from this .env (fallback only — DOES NOT override shell)
#   4. compiled default (lowest)
#
# REQUIRED — the compose stack refuses to boot without these:

# Postgres superuser password (the herald_app and herald_migrator
# roles are created during migration). Choose a strong random value.
HERALD_DB_PASSWORD=change-me-strong-postgres-password

# Redis ACL "default" user password. Strong random value.
HERALD_REDIS_PASSWORD=change-me-strong-redis-password

# HRD-010 commons_storage live wiring (landed 2026-05-20).
# Dev defaults below mirror the quickstart compose ports
# (Postgres 24100, Redis 24200) per §26.5 / §44.5. Operators
# MUST override HERALD_DB_PASSWORD + HERALD_REDIS_PASSWORD in
# production (per §11.4.10 these literal dev values are
# documentation, not secrets).

HERALD_DB_HOST=127.0.0.1
HERALD_DB_PORT=24100
HERALD_DB_USER=herald
# HERALD_DB_PASSWORD is set above (required block).
HERALD_DB_NAME=herald

# DSN form used by `pherald migrate` CLI (composed from the
# HERALD_DB_* values above). Set this when the CLI is invoked
# from a context that doesn't already carry the split env vars.
HERALD_PG_DSN=postgres://herald:herald_dev@127.0.0.1:24100/herald

# Redis (HRD-010 + future caching/rate-limiting per §15 + §44.6).
HERALD_REDIS_ADDR=127.0.0.1:24200
# HERALD_REDIS_PASSWORD is set above (required block).
HERALD_REDIS_DB=0

# ----- Optional: Telegram channel ----------------------------------
# Obtain by chatting with @BotFather in Telegram. The chat ID is the
# numeric channel/group id (use /id or @userinfobot to obtain it).

# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# TELEGRAM_CHAT_ID=-1001234567890

# ----- Optional: Slack channel -------------------------------------
# Incoming-webhook URL for the simple fan-out case. The webhook format
# is https://hooks.slack.com/services/T.../B.../...

# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T0XXX/B0XXX/XXXXX

# ----- Optional: Email channel (raw SMTP) --------------------------
# When set, the mailto:// adapter sends via this SMTP relay. For
# Resend / Postmark / SendGrid, use their respective env vars instead
# (see spec §11.9).

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=herald@example.com
# SMTP_PASSWORD=change-me-strong-smtp-password

# ----- Optional: Email channel (Resend transactional) --------------
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM=herald@example.com

# ----- Project identity --------------------------------------------
# Used for Claude Code session resolution (§33.2). MUST match the
# folder name of the consuming project (e.g. "ATMOSphere") so the
# session anchor at <project>/.herald/claude-code/sessions/<name>.session
# is found.

HERALD_PROJECT_NAME=Herald

# ----- Tenant scoping (defaults are fine for single-tenant) --------
HERALD_TENANT_ID=00000000-0000-0000-0000-000000000001

# ----- Optional: alternative database encryption key for credential
# storage (§15.4). Only required if Herald itself encrypts at rest
# (versus relying on the host's full-disk encryption).

# HERALD_DB_ENC_KEY=change-me-32-byte-hex-encoded-aes-key
